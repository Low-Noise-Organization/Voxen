{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "group:allNonMajor",
    ":separateMajorMinor",
    ":combinePatchMinorUpdates"
  ],
  "labels": ["dependencies", "automated"],
  "packageRules": [
    {
      "matchPackagePatterns": ["^org\\.junit"],
      "groupName": "JUnit"
    },
    {
      "matchPackagePatterns": ["^com\\.fasterxml"],
      "groupName": "Jackson"
    },
    {
      "matchPackagePatterns": ["^info\\.picocli"],
      "groupName": "Picocli"
    },
    {
      "matchPackagePatterns": ["^org\\.apache\\.commons"],
      "groupName": "Apache Commons"
    }
  ],
  "vulnerabilityAlerts": {
    "labels": ["security"]
  },
  "schedule": ["before 9am on monday"]
}
